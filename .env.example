# App — use your real production domain (NOT a preview URL like
# https://inkday-xxxxx-inkday.vercel.app). Preview hosts break auth redirects
# and invite links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Local SQLite
# DATABASE_URL=file:./data/inkday.db

# Turso (production / hosted)
# DATABASE_URL=libsql://YOUR-DB.turso.io
# DATABASE_AUTH_TOKEN=YOUR_TOKEN

# Inkday Plus preview (no Stripe yet) — redeem on Profile
PREMIUM_PROMO_CODE=inkday-plus

# Cron for reminder outbox: GET /api/cron/notifications
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-with-a-long-random-secret
